#include <iostream>
#include <string>
#include <ios>
#include <iomanip>

using std::cin; using std::cout;
using std::endl; using std::string;
using std::setprecision; using std::streamsize;

int main(void) {

    cout << "Celect country: 1. Korea, 2. USA";
    int option;
    cin >> option;

    string name = "", fname, lname; 
    double att = 0.1,
    mid = 0.3,
    fin = 0.3,
    hw = 0.25,
    project = 0,5;

while (option != 1 && option !=2 ) {
    cout << "Select country: 1. Korea, 2. USA >>>";
    cin >> option;

    if (option == 1) { // Korea
    cout << "Name: "; 
    cin >> name;
    }
    else if (option == 2) { // USA
        cout << "First Name + Last Name: "; 
        cin >> fname >> lname;
        name = fname + "" + lname;
    }
    cout << "Hello, " << name << "!" << endl; 
}

    double midterm, final, sum = 0;
    int count = 0;

    cout << "Midterm + Final grades: ";
    cin >> midterm >> final; // 45 65 => 

    cout << "All HW grades + EOF: "; // EOF: (CTRL + D) + ENTER

    double in;

    while (cin >> in) {
        ++count;
        sum += in;
    }

    streamsize prec = cout.precision ();

    /*
    cout << name << "'s Final grade: " << setprecision(3)
        << 0.2 * midterm + 0.4 * final + 0.4 * (sum / count)
        << setprecision(prec) << endl;
    */

    cout << name << "'s Final grade: "
       << (att * 100)
        + (mid * midterm) 
        + (fin * final) 
        + (hw * (sum / count))
        + (project * 100)
        << endl;
    

    return 0;
}