// quartiles.cpp
#include <iostream>
#include <vector>
#include <algorithm>


double findMedian(vector<double>& arr, int start, int end) {
    int n = end - start + 1;
    if (n % 2 == 0) {
        return (arr[start + n/2 - 1] + arr[start + n/2]) / 2.0;
    } else {
        return arr[start + n/2];
    }
}

int main() {
    int n;
    cout << "Enter number: ";
    cin >> n;

    vector<double> arr(n);

    cout << "Enter numbers: ";
    for (int i = 0; i < n; i++) {
        cin >> arr[i];
    }

    sort(arr.begin(), arr.end());

    double Q2 = findMedian(arr, 0, n - 1);

    double Q1, Q3;

    if (n % 2 == 0) {
        Q1 = findMedian(arr, 0, n/2 - 1);
        Q3 = findMedian(arr, n/2, n - 1);
    } else {
        Q1 = findMedian(arr, 0, n/2 - 1);
        Q3 = findMedian(arr, n/2 + 1, n - 1);
    }

    cout << "Q1: " << Q1 << endl;
    cout << "Q2 (Median): " << Q2 << endl;
    cout << "Q3: " << Q3 << endl;

    return 0;
}