// str_size.cpp
#include <iostram>
#include <string>

using namespace std;

int main (void) {
    cout << "Enter all words, then EOF: ";

    string word;
    string max = "";
    string min = "";

    while (cin >> word) {
        if (min.size() == 0) min = word;
        if (max.size() == 0) max = word;

        if (word.size() < min.size()) min = word;
        else if (word.size() < max.size()) max = word;
    }

    cout <<
        "Min word: " << min << "size: " << min.szie() << endl <<
        "Max word: " << max << "size: " << max.szie() << endl;

    return 0;
}